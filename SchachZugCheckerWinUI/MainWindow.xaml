<Window
    x:Class="SchachZugCheckerWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:SchachZugCheckerWinUI.Model"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid AllowDrop="True" DragOver="Field_DragOver">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Margin="0,0,8,0" Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Margin="4" Text="Zug Hilfe:" VerticalAlignment="Center" FontSize="16"/>
            <ToggleSwitch x:Name="ts_MoveHelp" Margin="4,4,16,4" IsOn="{Binding MoveHelp, Mode=TwoWay}" />
            
            <TextBlock Margin="4" Text="Connect:" VerticalAlignment="Center" FontSize="16"/>
            <Border Background="{Binding StatusColorBrush}" CornerRadius="50" Width="20" Height="20" Margin="4"/>
            
            <Button x:Name="bt_Restart" Margin="4" Width="100" Content="Reset" Command="{Binding RestartCommand}"/>
            <Button x:Name="bt_Open" Margin="4" Width="100" Content="Open" Command="{Binding OpenCommand}" Visibility="{Binding OpenVisi}"/>
            <Button x:Name="bt_Close" Margin="4" Width="100" Content="Close" Command="{Binding CloseCommand}" Visibility="{Binding CloseVisi}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <Viewbox Grid.Column="0" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid x:Name="BoardContainer" Width="800" Height="720">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="700"/>
                        <RowDefinition Height="20"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="700"/>
                    </Grid.ColumnDefinitions>

                    <!-- Turn Indicator & Timer -->
                    <Grid Grid.Row="0" Grid.Column="0" Width="80" VerticalAlignment="Stretch">
                        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,34,0,0">
                            <Border Background="{Binding BlackTurnBrush}" BorderBrush="{Binding BlackTurnBorderBrush}" BorderThickness="2" CornerRadius="50" Width="20" Height="20" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding BlackTimeStr}" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>

                        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,34">
                            <TextBlock Text="{Binding WhiteTimeStr}" HorizontalAlignment="Center" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
                            <Border Background="{Binding WhiteTurnBrush}" BorderBrush="{Binding WhiteTurnBorderBrush}" BorderThickness="2" CornerRadius="50" Width="20" Height="20" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Row labels -->
                    <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Stretch" Width="20">
                        <TextBlock Text="8" Height="87.5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="7" Height="87.5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="6" Height="87.5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="5" Height="87.5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="4" Height="87.5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="3" Height="87.5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="2" Height="87.5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="1" Height="87.5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Column labels -->
                    <Grid Grid.Row="1" Grid.Column="2" Height="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="A" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="B" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="C" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="D" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="E" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="F" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="G" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="7" Text="H" HorizontalAlignment="Center"/>
                    </Grid>

                    <ItemsControl Grid.Row="0" Grid.Column="2" ItemsSource="{Binding ChessFields}" Background="Transparent">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="8" ItemWidth="87.5" ItemHeight="87.5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="model:VisualChessField">
                                <Grid Width="87.5" Height="87.5" AllowDrop="True" DragOver="Field_DragOver" Drop="Field_Drop" Background="Transparent" Tapped="Field_Tapped">
                                    <Border Background="{Binding BackgroundBrush}"/>
                                    <Image Source="{Binding Figur}" Margin="8" CanDrag="True" DragStarting="Image_DragStarting" DropCompleted="Image_DropCompleted" Opacity="{Binding Opacity}"/>
                                    <Border BorderBrush="{Binding HighlightBrush}" BorderThickness="4" 
                                            Visibility="{Binding HighlightVisibility}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Viewbox>

            <!-- History Area -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Spielverlauf" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                <ListView Grid.Row="1" ItemsSource="{Binding GameHistory}" Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="model:GameHistoryEntry">
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Column="0" Background="{Binding PlayerColorBrush}" BorderBrush="{Binding PlayerBorderBrush}" 
                                        BorderThickness="1" CornerRadius="50" Width="12" Height="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                
                                <TextBlock Grid.Column="1" Text="{Binding Time}" FontSize="12" Foreground="Gray" VerticalAlignment="Center"/>
                                
                                <TextBlock Grid.Column="2" Text="{Binding Move}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Window>
